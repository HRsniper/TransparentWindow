<Window
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Transparent Window"
  Width="400"
  Height="600"
  WindowStyle="None"
  AllowsTransparency="True"
  Background="Transparent"
  ResizeMode="NoResize"
  WindowStartupLocation="CenterScreen"
  FontFamily="Segoe UI">

  <Window.Resources>
    <!-- DRACULA COLORS -->
    <SolidColorBrush x:Key="DraculaBackground" Color="#282a36" />
    <SolidColorBrush x:Key="DraculaCurrentLine" Color="#44475a" />
    <SolidColorBrush x:Key="DraculaForeground" Color="#f8f8f2" />
    <SolidColorBrush x:Key="DraculaComment" Color="#6272a4" />
    <SolidColorBrush x:Key="DraculaPurple" Color="#bd93f9" />
    <SolidColorBrush x:Key="DraculaCyan" Color="#8be9fd" />
    <SolidColorBrush x:Key="DraculaGreen" Color="#50fa7b" />
    <SolidColorBrush x:Key="DraculaRed" Color="#ff5555" />
    <SolidColorBrush x:Key="DraculaOrange" Color="#ffb86c" />
    <SolidColorBrush x:Key="DraculaPink" Color="#ff79c6" />
    <SolidColorBrush x:Key="DraculaYellow" Color="#f1fa8c" />

    <x:Double x:Key="CornerRadiusBase">8</x:Double>

    <!-- FONTES CENTRALIZADAS (ESCALA BASEADA EM 14PT) -->
    <x:Double x:Key="FontSizeBase">14</x:Double>
    <x:Double x:Key="FontSizeSmall">12</x:Double>
    <x:Double x:Key="FontSizeTitle">16</x:Double>
    <FontWeight x:Key="FontWeightRegular">Normal</FontWeight>
    <FontWeight x:Key="FontWeightMedium">Medium</FontWeight>
    <FontWeight x:Key="FontWeightSemiBold">SemiBold</FontWeight>
    <FontWeight x:Key="FontWeightBold">Bold</FontWeight>

    <!-- TEXT STYLE -->
    <Style x:Key="TextTitle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource DraculaForeground}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="TextSection" TargetType="TextBlock">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="{StaticResource DraculaComment}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="TextPrimary" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource DraculaForeground}" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="Regular" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="TextSecondary" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource DraculaComment}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Regular" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>


    <!-- GRID STYLE -->
    <Style x:Key="GridSectionContainer" TargetType="Grid">
      <Setter Property="Margin" Value="14" />
    </Style>

    <!-- SCROLLBAR STYLES -->
    <Style x:Key="DraculaScrollBarThumb" TargetType="Thumb">
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Background" Value="{StaticResource DraculaComment}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Border Background="{TemplateBinding Background}" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{StaticResource DraculaPurple}" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="DraculaScrollBar" TargetType="ScrollBar">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollBar">
            <!-- Name="PART_Track" é essencial -->
            <Track Name="PART_Track" IsDirectionReversed="True">
              <Track.Thumb>
                <Thumb Style="{StaticResource DraculaScrollBarThumb}" />
              </Track.Thumb>
            </Track>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DraculaScrollViewer" TargetType="ScrollViewer">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollViewer">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="4" />
              </Grid.ColumnDefinitions>
              <ScrollContentPresenter Grid.Column="0" />
              <ScrollBar
                Grid.Column="1"
                Name="PART_VerticalScrollBar"
                Style="{StaticResource DraculaScrollBar}"
                Value="{TemplateBinding VerticalOffset}"
                Maximum="{TemplateBinding ScrollableHeight}"
                ViewportSize="{TemplateBinding ViewportHeight}"
                Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- LISTVIEW ITEM STYLE -->
    <Style x:Key="DraculaListViewItem" TargetType="ListViewItem">
      <Setter Property="Foreground" Value="{StaticResource DraculaForeground}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListViewItem">
            <Grid>
              <!-- accent bar — só visível quando selecionado -->
              <Rectangle
                x:Name="AccentBar"
                Width="4"
                Fill="{StaticResource DraculaPurple}"
                HorizontalAlignment="Left"
                Visibility="Collapsed" />
              <Border
                x:Name="WindowItem"
                Padding="4"
                Margin="4,0,0,0">
                <ContentPresenter />
              </Border>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="WindowItem" Property="Background"
                  Value="{StaticResource DraculaCurrentLine}" />
                <Setter TargetName="AccentBar" Property="Visibility" Value="Visible" />
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsMouseOver" Value="True" />
                  <Condition Property="IsSelected" Value="False" />
                </MultiTrigger.Conditions>
                <Setter TargetName="WindowItem" Property="Background"
                  Value="{StaticResource DraculaCurrentLine}" />
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- SLIDER STYLES -->
    <Style x:Key="DraculaSliderThumb" TargetType="Thumb">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Grid>
              <Ellipse Width="28" Height="28" Fill="{StaticResource DraculaPurple}"
                Opacity="0.5" />
              <Ellipse Width="20" Height="20" Fill="{StaticResource DraculaPurple}" />
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DraculaSlider" TargetType="Slider">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Slider">
            <!-- Name="PART_Track" é essencial para scroll fica liso -->
            <Track Name="PART_Track">
              <Track.DecreaseRepeatButton>
                <RepeatButton Command="Slider.DecreaseLarge">
                  <RepeatButton.Template>
                    <ControlTemplate TargetType="RepeatButton">
                      <Border
                        Height="6"
                        Background="{StaticResource DraculaPurple}" />
                    </ControlTemplate>
                  </RepeatButton.Template>
                </RepeatButton>
              </Track.DecreaseRepeatButton>
              <Track.IncreaseRepeatButton>
                <RepeatButton Command="Slider.IncreaseLarge">
                  <RepeatButton.Template>
                    <ControlTemplate TargetType="RepeatButton">
                      <Border
                        Height="4"
                        Background="{StaticResource DraculaCurrentLine}" />
                    </ControlTemplate>
                  </RepeatButton.Template>
                </RepeatButton>
              </Track.IncreaseRepeatButton>
              <Track.Thumb>
                <Thumb Style="{StaticResource DraculaSliderThumb}" />
              </Track.Thumb>
            </Track>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Setter Property="TickFrequency" Value="10" />
      <Setter Property="IsSnapToTickEnabled" Value="True" />
    </Style>

    <!-- TOGGLE BASE STYLE -->
    <Style x:Key="ToggleBase" TargetType="ToggleButton">
      <Setter Property="Background" Value="{StaticResource DraculaCurrentLine}" />
      <Setter Property="Foreground" Value="{StaticResource DraculaComment}" />
      <Setter Property="Height" Value="48" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
      <Setter Property="FontWeight" Value="{StaticResource FontWeightMedium}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border
              x:Name="Bd"
              Background="{TemplateBinding Background}"
              CornerRadius="8"
              BorderThickness="1"
              BorderBrush="{StaticResource DraculaComment}">
              <ContentPresenter HorizontalAlignment="Center"
                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush"
                  Value="{StaticResource DraculaPurple}" />
                <Setter Property="Foreground" Value="{StaticResource DraculaPurple}" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush"
                  Value="{StaticResource DraculaForeground}" />
                <Setter Property="Foreground"
                  Value="{StaticResource DraculaForeground}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bd" Property="Background"
                  Value="{StaticResource DraculaBackground}" />
                <Setter TargetName="Bd" Property="BorderBrush"
                  Value="{StaticResource DraculaCurrentLine}" />
                <Setter Property="Foreground"
                  Value="{StaticResource DraculaCurrentLine}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>


    <!-- BUTTON ICON STYLE -->
    <Style x:Key="ButtonIconBase" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource DraculaComment}" />
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontSize" Value="{StaticResource FontSizeBase}" />
      <Setter Property="FontWeight" Value="{StaticResource FontWeightRegular}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
              CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background"
                  Value="{StaticResource DraculaCurrentLine}" />
                <Setter Property="Foreground"
                  Value="{StaticResource DraculaForeground}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ButtonIconClose" TargetType="Button" BasedOn="{StaticResource ButtonIconBase}">
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Foreground" Value="{StaticResource DraculaRed}" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="ButtonIconRefresh" TargetType="Button"
      BasedOn="{StaticResource ButtonIconBase}">
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Foreground" Value="{StaticResource DraculaPurple}" />
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Border
    Background="{StaticResource DraculaBackground}"
    CornerRadius="8"
    BorderBrush="{StaticResource DraculaCurrentLine}"
    BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="auto" />    <!-- TITLE BAR  -->
        <RowDefinition Height="1" />     <!-- SEPARATOR -->
        <RowDefinition Height="auto" />  <!-- OPEN WINDOW -->
        <RowDefinition Height="*" />     <!-- LISTVIEW OF WINDOWS -->
        <RowDefinition Height="1" />     <!-- SEPARATOR -->
        <RowDefinition Height="auto" />  <!-- TRANSPARENCY -->
        <RowDefinition Height="1" />     <!-- SEPARATOR -->
        <RowDefinition Height="auto" />  <!-- ACTIONS -->
        <RowDefinition Height="1" />     <!-- SEPARATOR -->
        <RowDefinition Height="auto" />    <!-- STATUS BAR -->
      </Grid.RowDefinitions>

      <!-- TITLE BAR -->
      <Grid Grid.Row="0" x:Name="TitleBar" Style="{StaticResource GridSectionContainer}">
        <TextBlock
          Text="TRANSPARENT WINDOW"
          Style="{StaticResource TextTitle}"
          HorizontalAlignment="Center" />
        <Grid HorizontalAlignment="Right" VerticalAlignment="Center">
          <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="4" />
            <ColumnDefinition />
          </Grid.ColumnDefinitions>
          <Button Grid.Column="0" x:Name="BtnMinimize"
            Content="─"
            Style="{StaticResource ButtonIconBase}" />
          <Button Grid.Column="2" x:Name="BtnClose"
            Content="✕"
            Style="{StaticResource ButtonIconClose}" />
        </Grid>
      </Grid>

      <!-- SEPARATOR -->
      <Rectangle Grid.Row="1" Fill="{StaticResource DraculaCurrentLine}" />

      <!-- OPEN WINDOW -->
      <Grid Grid.Row="2" Style="{StaticResource GridSectionContainer}">
        <TextBlock
          Text="JANELAS ABERTAS"
          Style="{StaticResource TextSection}"
          HorizontalAlignment="Left" />
        <Button x:Name="BtnRefresh"
          Content="🔄️"
          Style="{StaticResource ButtonIconRefresh}"
          HorizontalAlignment="Right" />
      </Grid>

      <!-- LISTVIEW OF WINDOWS -->
      <Grid Grid.Row="3" Style="{StaticResource GridSectionContainer}">
        <ListView x:Name="WindowList"
          Background="Transparent"
          BorderThickness="0"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
          ScrollViewer.VerticalScrollBarVisibility="Auto"
          ItemContainerStyle="{StaticResource DraculaListViewItem}">
          <ListView.Resources>
            <Style TargetType="ScrollViewer"
              BasedOn="{StaticResource DraculaScrollViewer}" />
          </ListView.Resources>
          <!-- Example items (will be replaced by PowerShell) -->
          <ListViewItem>
            <StackPanel>
              <TextBlock
                Text="Notepad"
                Style="{StaticResource TextPrimary}" />
              <TextBlock
                Text="notepad.exe"
                Style="{StaticResource TextSecondary}" />
            </StackPanel>
          </ListViewItem>
          <ListViewItem>
            <StackPanel>
              <TextBlock
                Text="GitHub - Google Chrome"
                Style="{StaticResource TextPrimary}" />
              <TextBlock
                Text="chrome.exe"
                Style="{StaticResource TextSecondary}" />
            </StackPanel>
          </ListViewItem>
        </ListView>
      </Grid>

      <!-- SEPARATOR -->
      <Rectangle Grid.Row="4" Fill="{StaticResource DraculaCurrentLine}" />

      <!-- TRANSPARENCY -->
      <Grid Grid.Row="5" Style="{StaticResource GridSectionContainer}">
        <Grid.RowDefinitions>
          <RowDefinition />
          <RowDefinition Height="12" />
          <RowDefinition />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
          <TextBlock
            Text="TRANSPARÊNCIA"
            Style="{StaticResource TextSection}"
            HorizontalAlignment="Left" />
          <TextBlock x:Name="SliderValueLabel"
            Text="100%"
            Style="{StaticResource TextSection}"
            HorizontalAlignment="Right" />
        </Grid>
        <Slider Grid.Row="2" x:Name="TransparencySlider"
          Style="{StaticResource DraculaSlider}"
          Minimum="10"
          Maximum="100"
          Value="100"
          IsEnabled="False" />
      </Grid>

      <!-- SEPARATOR -->
      <Rectangle Grid.Row="6" Fill="{StaticResource DraculaCurrentLine}" />

      <!-- ACTIONS SECTION -->
      <Grid Grid.Row="7" Style="{StaticResource GridSectionContainer}">
        <Grid.RowDefinitions>
          <RowDefinition />
          <RowDefinition Height="12" />
          <RowDefinition />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
          Text="AÇÕES"
          Style="{StaticResource TextSection}" />
        <Grid Grid.Row="2">
          <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="12" />
            <ColumnDefinition />
          </Grid.ColumnDefinitions>
          <ToggleButton
            Grid.Column="0"
            x:Name="ToggleFixar"
            Style="{StaticResource ToggleBase}"
            IsEnabled="False">
            <TextBlock
              Text="📌 Fixar no Topo" />
          </ToggleButton>
          <ToggleButton
            Grid.Column="2"
            x:Name="TogglePassivo"
            Style="{StaticResource ToggleBase}"
            IsEnabled="False">
            <TextBlock Text="👁️ Modo Passivo" />
          </ToggleButton>
        </Grid>
      </Grid>

      <!-- SEPARATOR -->
      <Rectangle Grid.Row="8" Fill="{StaticResource DraculaCurrentLine}" />

      <!-- STATUS BAR -->
      <Grid Grid.Row="9" Style="{StaticResource GridSectionContainer}">
        <Ellipse x:Name="StatusDot"
          Width="8"
          Height="8"
          Fill="{StaticResource DraculaComment}"
          HorizontalAlignment="Left"
          VerticalAlignment="Center" />
        <TextBlock x:Name="StatusLabel"
          Text="Nenhuma janela selecionada"
          Style="{StaticResource TextSecondary}"
          Margin="16,0,0,0" />
      </Grid>
    </Grid>
  </Border>
</Window>